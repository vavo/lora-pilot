# Build-time configuration (Dockerfile ARGs)
# Copy to `build.env` if you want, then export vars before building.
#
# Notes:
# - These variables only affect image builds (Dockerfile `ARG`), not runtime.
# - They are NOT read by `docker-compose.yml` in this repo because it uses a prebuilt image.
#
# Build examples:
# - Makefile: `make build CUDA_PROFILE=cu130 INSTALL_GPU_STACK=1 INSTALL_INVOKE=1 INSTALL_AI_TOOLKIT=1`
# - Docker:   `docker build --build-arg CUDA_PROFILE=cu130 --build-arg CUDA_BASE_IMAGE=nvidia/cuda:13.0.2-runtime-ubuntu22.04 --build-arg TORCH_VERSION=2.12.0 -t lora-pilot:dev .`

# ========================================
# CUDA PROFILE
# ========================================
# Default Blackwell profile. Use cu128 values below for the legacy CUDA 12.8 build.
CUDA_PROFILE=cu130
CUDA_BASE_IMAGE=nvidia/cuda:13.0.2-runtime-ubuntu22.04

# ========================================
# COMPONENT INSTALLATION (0/1)
# ========================================
INSTALL_GPU_STACK=1
INSTALL_COMFY=1
INSTALL_KOHYA=1
INSTALL_INVOKE=1
INSTALL_DIFFPIPE=1
INSTALL_AI_TOOLKIT=1
INSTALL_AI_TOOLKIT_UI=1
INSTALL_COPILOT_CLI=1

# ========================================
# COPILOT CLI
# ========================================
# Default pinned to the latest published Copilot CLI package version.
COPILOT_CLI_VERSION=1.0.10

# ========================================
# DEV TOOLS
# ========================================
CODE_SERVER_VERSION=4.123.0
JUPYTERLAB_VERSION=4.5.8
IPYWIDGETS_VERSION=8.1.8

# ========================================
# UPSTREAM REFS
# ========================================
# Defaults are pinned to verified upstream refs instead of floating on repo HEAD.
COMFYUI_REF=v0.24.1
COMFYUI_MANAGER_REF=4.2.1
KOHYA_REF=v25.2.1
DIFFPIPE_REF=5aa65772168809346629d65a094d3a5523331669
AI_TOOLKIT_REF=88127557f5fdf7134ee8bce1e80ffd9e9f78d1de

# ========================================
# TRAINING STACKS
# ========================================
# AI Toolkit keeps its own venv but imports the shared core GPU stack.
AI_TOOLKIT_DIFFUSERS_VERSION=git
DIFFPIPE_DIFFUSERS_VERSION=0.38.0
DIFFPIPE_TRANSFORMERS_VERSION=5.11.0

# ========================================
# VERSION PINS (GPU STACK)
# ========================================
TORCH_VERSION=2.12.0
TORCHVISION_VERSION=0.27.0
# cu130 currently has no matching torchaudio 2.12.0 wheel; leave empty to skip.
TORCHAUDIO_VERSION=
TORCH_INDEX_URL=https://download.pytorch.org/whl/cu130

# CUDA 12.8 legacy profile:
# CUDA_PROFILE=cu128
# CUDA_BASE_IMAGE=nvidia/cuda:12.8.1-runtime-ubuntu22.04
# TORCH_VERSION=2.11.0
# TORCHVISION_VERSION=0.26.0
# TORCHAUDIO_VERSION=2.11.0
# TORCH_INDEX_URL=https://download.pytorch.org/whl/cu128
# CUDA_NVCC_PKG=cuda-nvcc-12-8

XFORMERS_VERSION=0.0.35
BITSANDBYTES_VERSION=0.49.2
CORE_DIFFUSERS_VERSION=0.38.0
TRANSFORMERS_VERSION=5.11.0
PEFT_VERSION=0.19.1
ACCELERATE_VERSION=1.14.0
HF_HUB_VERSION=1.19.0

# ========================================
# VERSION PINS (INVOKE VENV, IMPORTS SHARED GPU STACK)
# ========================================
INVOKEAI_VERSION=6.13.0
INVOKE_DIFFUSERS_VERSION=0.36.0
INVOKE_TRANSFORMERS_VERSION=4.57.6
INVOKE_ACCELERATE_VERSION=1.14.0
INVOKE_HF_HUB_VERSION=0.36.2

# ========================================
# SYSTEM PACKAGES / TOOLS
# ========================================
CUDA_NVCC_PKG=cuda-nvcc-13-0
CROC_VERSION=10.4.2
